{
  "compilerOptions": {
    "target": "ES2019",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2019", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "types": ["node"]
  },
  "include": ["client.ts", "server.ts", "src/**/*.ts", "types/**/*.d.ts"],
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "allowJs": false
    }
  }
}
